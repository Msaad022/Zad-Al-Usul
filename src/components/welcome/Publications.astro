---
import ruqyabook from "../../assets/ruqya-shar3iya-book-cover.svg";
---

<section
  class="my-4 sm:my-8 rounded-lg border px-3 py-5 bg-light-m dark:bg-dark-m"
>
  <h2
    id="publications-heading"
    class="text-lg font-bold mb-4 dark:text-white-h"
  >
    المؤلفات
  </h2>
  <ul class="relative space-y-8 ms-1 sm:ms-3">
    <li class="ms-5">
      <div
        class="absolute w-3 h-3 bg-gray-400 dark:bg-gray-b rounded-full -start-[7px] translate-y-2/4"
        aria-hidden="true"
      >
      </div>
      <article>
        <figure class="flex flex-col sm:flex-row gap-4">
          <img
            src={ruqyabook.src}
            width="80"
            height="120"
            loading="lazy"
            title="كتاب الرقية الشرعية: أحكامها وآدابها وضوابطها"
            class="shrink-0 mx-auto sm:mx-0"
            alt="غلاف كتاب الرقية الشرعية: أحكامها وآدابها وضوابطها"
          />
          <figcaption class="mt-1.5">
            <h3
              id="publications-1"
              class="text-base font-semibold mb-2.5 dark:text-white-h"
              aria-labelledby="publications-heading publications-1"
            >
              الرقية الشرعية: أحكامها وآدابها وضوابطها
            </h3>
            <div>
              <p>
                كتاب يضم الأذكار النبوية الصحيحة مع بيان ضوابط الرقية وآدابها.
              </p>
            </div>
          </figcaption>
        </figure>
      </article>
    </li>
  </ul>
</section>
