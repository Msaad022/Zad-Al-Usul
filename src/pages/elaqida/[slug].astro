---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { AudioPlayer } from "../../components";
import { getQuestionBySlug } from "../../utils/roleCheck";

const { slug } = Astro.params;

let question: Awaited<ReturnType<typeof getQuestionBySlug>> = null;
let errorMessage: string | null = null;

try {
  question = await getQuestionBySlug(slug ?? undefined);
} catch (err) {
  errorMessage = err instanceof Error ? err.message : "حدث خطأ في تحميل البيانات.";
}

if (errorMessage) {
  return Astro.redirect("/elaqida?error=" + encodeURIComponent(errorMessage));
}

// Playable media URL: must be Cloudinary secure URL or same-origin path (old seed data)
const audioPlaybackUrl = question?.secure_url ?? "";


const notFound = !question;
const questionData = notFound ? null : question;
const words = questionData && Array.isArray(questionData.words)
  ? (questionData.words as Array<{ text: string; start: number; end: number }>)
  : [];


if (notFound) {
  Astro.response.status = 404;
}
---

{notFound ? (
  <Layout>
    <Fragment slot="head-meta">
      <title>زاد الأصول | السؤال غير موجود</title>
    </Fragment>
    <section class="not-found-section" aria-labelledby="not-found-title">
      <h1 id="not-found-title">السؤال غير موجود</h1>
      <p>لم يتم العثور على السؤال المطلوب. تأكد من الرابط أو ارجع إلى <a href="/elaqida">قائمة الأسئلة</a>.</p>
    </section>
    <style>
      .not-found-section {
        max-width: 36rem;
        margin: 2rem auto;
        padding: 2rem;
        text-align: center;
      }
      .not-found-section h1 {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
      }
      .not-found-section a {
        color: var(--spotify-green, #1db954);
        text-decoration: underline;
      }
    </style>
  </Layout>
) : questionData ? (
  <Layout>
    <Fragment slot="head-meta">
      <title>زاد الأصول | {questionData.question}</title>
    </Fragment>

    <AudioPlayer
      audioPosts={{
        id: questionData.id,
        type_que: questionData.type_que ?? "",
        question: questionData.question ?? "",
        answer: questionData.answer ?? "",
        description: questionData.description ?? "",
        words,
      }}
      audioCloudUrl={audioPlaybackUrl}
    />
  </Layout>
) : null}
