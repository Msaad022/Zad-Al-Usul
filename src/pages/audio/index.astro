<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>مشغل الصوت المتزامن</title>
  </head>
  <body>
    <div class="page">
      <div class="audio-player-container">
        <header class="audio-header">
          <div class="audio-header-text">
            <h1>مشغل الصوت المتزامن</h1>
            <p>استمع إلى الدرس وتابع النص المتزامن مع الصوت بسهولة.</p>
          </div>
        </header>

        <section class="audio-main">
          <audio id="audioElement" src="/public/El Aqida/3aqeeda1.ogg"></audio>

          <div class="visualizer-wrapper">
            <div class="visualizer-header">
              <span class="visualizer-title">موجة الصوت الحية</span>
            </div>
            <canvas id="visualizerCanvas"></canvas>
          </div>

          <div class="progress-section">
            <div class="time-display">
              <span id="currentTime">00:00</span>
              <span class="time-separator">/</span>
              <span id="totalTime">00:00</span>
            </div>
            <input type="range" id="progressBar" value="0" step="0.01" />
          </div>

          <div class="controls-grid">
            <button id="playPauseBtn" class="primary-control"> تشغيل </button>

            <div class="slider-group">
              <div class="slider-label-row">
                <span class="slider-label">مستوى الصوت</span>
                <span class="slider-value" id="volumeValue">100%</span>
              </div>
              <input
                type="range"
                id="volumeSlider"
                min="0"
                max="1"
                step="0.01"
                value="1"
              />
            </div>

            <div class="slider-group">
              <div class="slider-label-row">
                <span class="slider-label">سرعة التشغيل</span>
                <span class="slider-value" id="speedValue">1.0x</span>
              </div>
              <input
                type="range"
                id="speedSlider"
                min="0.5"
                max="2"
                step="0.1"
                value="1"
              />
            </div>

            <button id="repeatBtn" class="secondary-control"> تكرار </button>
          </div>
        </section>

        <section class="transcript-section">
          <div class="transcript-header">
            <h2>النص المتزامن مع الصوت</h2>
            <p class="transcript-hint">
              اضغط على أي كلمة للانتقال مباشرة إلى موضعها في الملف الصوتي.
            </p>
          </div>
          <div id="transcript-container"></div>
        </section>
      </div>
    </div>
    <style is:inline>
      :root {
        --player-primary: #2563eb;
        --player-primary-dark: #1d4ed8;
        --player-accent: #22c55e;
        --player-bg: #020617;
        --player-card-bg: #0f172a;
        --player-border-subtle: rgba(148, 163, 184, 0.35);
        --player-text-main: #e5e7eb;
        --player-text-muted: #9ca3af;
        --player-surface-soft: rgba(15, 23, 42, 0.85);
      }

      body {
        background: radial-gradient(circle at top, #1e293b 0, #020617 55%);
        font-family:
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        direction: rtl;
        color: var(--player-text-main);
      }

      .page {
        width: 100%;
        padding: 1.5rem;
        box-sizing: border-box;
      }

      .audio-player-container {
        margin: 0 auto;
        width: 100%;
        max-width: 880px;
        background:
          linear-gradient(
            135deg,
            rgba(37, 99, 235, 0.18),
            rgba(15, 23, 42, 0.94)
          ),
          var(--player-card-bg);
        border-radius: 1.75rem;
        box-shadow:
          0 24px 80px rgba(15, 23, 42, 0.85),
          0 0 0 1px rgba(148, 163, 184, 0.35);
        padding: 1.75rem 1.75rem 1.5rem;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(148, 163, 184, 0.45);
        box-sizing: border-box;
        display: grid;
        grid-template-rows: auto auto auto;
        row-gap: 1.5rem;
      }

      .audio-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.4);
      }

      .audio-header-text h1 {
        margin: 0 0 0.3rem;
        font-size: 1.35rem;
        letter-spacing: 0.02em;
      }

      .audio-header-text p {
        margin: 0;
        font-size: 0.9rem;
        color: var(--player-text-muted);
      }

      .audio-main {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .visualizer-wrapper {
        background: radial-gradient(
          circle at top left,
          rgba(37, 99, 235, 0.4),
          rgba(15, 23, 42, 0.95)
        );
        border-radius: 1.25rem;
        padding: 0.9rem 1rem 1rem;
        border: 1px solid rgba(148, 163, 184, 0.4);
        box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.85);
      }

      .visualizer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.6rem;
        color: var(--player-text-muted);
        font-size: 0.82rem;
      }

      .visualizer-title {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }

      .visualizer-title::before {
        content: "";
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: radial-gradient(
          circle,
          #22c55e 0,
          #22c55e 45%,
          #14532d 100%
        );
        box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.25);
      }

      #visualizerCanvas {
        width: 100%;
        height: 120px;
        background: radial-gradient(
          circle at center,
          #020617 0,
          #020617 30%,
          #020617 60%,
          #020617 100%
        );
        border-radius: 999px;
        display: block;
        border: 1px solid rgba(148, 163, 184, 0.4);
      }

      .progress-section {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      #progressBar {
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
        background: rgba(30, 64, 175, 0.3);
        height: 8px;
        border-radius: 999px;
        cursor: pointer;
        outline: none;
        border: 1px solid rgba(30, 64, 175, 0.75);
        box-shadow:
          inset 0 0 0 1px rgba(15, 23, 42, 0.9),
          0 0 0 1px rgba(15, 23, 42, 0.8);
      }

      #progressBar::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 18px;
        height: 18px;
        background: radial-gradient(
          circle at 30% 30%,
          #eff6ff,
          #60a5fa 55%,
          #1d4ed8 100%
        );
        border-radius: 50%;
        box-shadow:
          0 0 0 4px rgba(37, 99, 235, 0.4),
          0 2px 6px rgba(15, 23, 42, 0.9);
        border: 1px solid rgba(191, 219, 254, 0.9);
        cursor: pointer;
      }

      #progressBar::-moz-range-thumb {
        width: 18px;
        height: 18px;
        background: radial-gradient(
          circle at 30% 30%,
          #eff6ff,
          #60a5fa 55%,
          #1d4ed8 100%
        );
        border-radius: 50%;
        box-shadow:
          0 0 0 4px rgba(37, 99, 235, 0.4),
          0 2px 6px rgba(15, 23, 42, 0.9);
        border: 1px solid rgba(191, 219, 254, 0.9);
        cursor: pointer;
      }

      .time-display {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        font-size: 0.88rem;
        color: var(--player-text-muted);
        gap: 0.35rem;
        direction: ltr;
      }

      .time-separator {
        opacity: 0.4;
      }

      .controls-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(0, 1.35fr);
        grid-auto-rows: auto;
        gap: 0.85rem 1rem;
        align-items: stretch;
      }

      .primary-control,
      .secondary-control {
        cursor: pointer;
        border: none;
        padding: 0.72rem 1.1rem;
        border-radius: 999px;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition:
          background-color 0.22s ease,
          box-shadow 0.22s ease,
          transform 0.06s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        white-space: nowrap;
      }

      .primary-control {
        background: radial-gradient(
          circle at 20% 0,
          #60a5fa 0,
          #2563eb 35%,
          #1d4ed8 75%
        );
        color: white;
        box-shadow:
          0 18px 40px rgba(37, 99, 235, 0.55),
          0 0 0 1px rgba(191, 219, 254, 0.6);
      }

      .primary-control:hover {
        background: radial-gradient(
          circle at 20% 0,
          #93c5fd 0,
          #2563eb 40%,
          #1d4ed8 80%
        );
        box-shadow:
          0 20px 55px rgba(37, 99, 235, 0.7),
          0 0 0 1px rgba(219, 234, 254, 0.9);
        transform: translateY(-1px);
      }

      .primary-control:active {
        transform: translateY(0);
        box-shadow:
          0 10px 22px rgba(37, 99, 235, 0.65),
          0 0 0 1px rgba(219, 234, 254, 0.85);
      }

      .secondary-control {
        background: radial-gradient(
          circle at 20% 0,
          #bbf7d0 0,
          #22c55e 38%,
          #16a34a 80%
        );
        color: #022c22;
        box-shadow:
          0 16px 34px rgba(34, 197, 94, 0.5),
          0 0 0 1px rgba(187, 247, 208, 0.7);
      }

      .secondary-control:hover {
        background: radial-gradient(
          circle at 20% 0,
          #dcfce7 0,
          #22c55e 40%,
          #16a34a 80%
        );
        box-shadow:
          0 18px 48px rgba(34, 197, 94, 0.6),
          0 0 0 1px rgba(220, 252, 231, 0.95);
        transform: translateY(-1px);
      }

      .secondary-control:active {
        transform: translateY(0);
        box-shadow:
          0 10px 22px rgba(34, 197, 94, 0.5),
          0 0 0 1px rgba(220, 252, 231, 0.9);
      }

      .slider-group {
        background: radial-gradient(
          circle at top right,
          rgba(15, 23, 42, 0.9),
          rgba(15, 23, 42, 0.96)
        );
        border-radius: 1.25rem;
        padding: 0.7rem 0.85rem 0.8rem;
        border: 1px solid rgba(148, 163, 184, 0.8);
        box-shadow:
          inset 0 0 0 1px rgba(15, 23, 42, 0.95),
          0 14px 34px rgba(15, 23, 42, 0.85);
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }

      .slider-label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.83rem;
        color: var(--player-text-muted);
      }

      .slider-value {
        font-family:
          "SF Mono", ui-monospace, Menlo, Monaco, Consolas, "Liberation Mono",
          "Courier New", monospace;
        font-size: 0.78rem;
        padding: 0.12rem 0.6rem;
        border-radius: 999px;
        background-color: rgba(15, 23, 42, 0.9);
        border: 1px solid rgba(148, 163, 184, 0.6);
        color: #e5e7eb;
      }

      input[type="range"] {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        background: linear-gradient(
          to left,
          rgba(37, 99, 235, 0.85),
          rgba(59, 130, 246, 0.4)
        );
        height: 6px;
        border-radius: 999px;
        outline: none;
        cursor: pointer;
        border: 1px solid rgba(15, 23, 42, 0.9);
        box-shadow:
          inset 0 0 0 1px rgba(15, 23, 42, 0.8),
          0 0 0 1px rgba(15, 23, 42, 0.7);
      }

      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 16px;
        height: 16px;
        background: radial-gradient(
          circle at 30% 30%,
          #eff6ff,
          #60a5fa 55%,
          #1d4ed8 100%
        );
        border-radius: 50%;
        border: 1px solid rgba(191, 219, 254, 0.9);
        box-shadow:
          0 0 0 3px rgba(37, 99, 235, 0.35),
          0 2px 6px rgba(15, 23, 42, 0.85);
      }

      input[type="range"]::-moz-range-thumb {
        width: 16px;
        height: 16px;
        background: radial-gradient(
          circle at 30% 30%,
          #eff6ff,
          #60a5fa 55%,
          #1d4ed8 100%
        );
        border-radius: 50%;
        border: 1px solid rgba(191, 219, 254, 0.9);
        box-shadow:
          0 0 0 3px rgba(37, 99, 235, 0.35),
          0 2px 6px rgba(15, 23, 42, 0.85);
      }

      button:focus-visible,
      input[type="range"]:focus-visible {
        outline: 2px solid #e5e7eb;
        outline-offset: 2px;
      }

      .transcript-section {
        background: radial-gradient(
          circle at bottom left,
          rgba(37, 99, 235, 0.05),
          rgba(15, 23, 42, 1)
        );
        border-radius: 1.25rem;
        padding: 1rem 1rem 0.9rem;
        border: 1px solid rgba(148, 163, 184, 0.65);
        box-shadow:
          inset 0 0 0 1px rgba(15, 23, 42, 0.96),
          0 14px 36px rgba(15, 23, 42, 0.9);
      }

      .transcript-header h2 {
        margin: 0 0 0.25rem;
        font-size: 1.02rem;
      }

      .transcript-hint {
        margin: 0 0 0.6rem;
        font-size: 0.85rem;
        color: var(--player-text-muted);
      }

      #transcript-container {
        font-size: 1.05rem;
        line-height: 1.9;
        text-align: justify;
        padding: 0.7rem 0.3rem 0;
        border-radius: 0.75rem;
        max-height: 230px;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(148, 163, 184, 0.85) rgba(15, 23, 42, 0.95);
      }

      #transcript-container::-webkit-scrollbar {
        width: 6px;
      }

      #transcript-container::-webkit-scrollbar-track {
        background: rgba(15, 23, 42, 0.95);
        border-radius: 999px;
      }

      #transcript-container::-webkit-scrollbar-thumb {
        background: rgba(148, 163, 184, 0.9);
        border-radius: 999px;
      }

      .word {
        transition:
          color 0.2s ease,
          background-color 0.2s ease,
          box-shadow 0.2s ease;
        margin-inline: 0.17rem;
        padding: 0.12rem 0.22rem;
        border-radius: 0.4rem;
        cursor: pointer;
      }

      .word:hover {
        background-color: rgba(37, 99, 235, 0.2);
      }

      .highlighted {
        color: #f97316;
        background: rgba(248, 250, 252, 0.04);
        box-shadow:
          0 0 0 1px rgba(249, 115, 22, 0.5),
          0 0 18px rgba(249, 115, 22, 0.45);
        border-radius: 0.55rem;
      }

      @media (max-width: 768px) {
        .audio-player-container {
          padding: 1.25rem 1.15rem 1.1rem;
          border-radius: 1.5rem;
        }

        .audio-header-text h1 {
          font-size: 1.18rem;
        }

        .controls-grid {
          grid-template-columns: 1fr;
        }

        .visualizer-wrapper {
          padding-inline: 0.75rem;
        }

        #visualizerCanvas {
          height: 100px;
        }

        #transcript-container {
          max-height: 190px;
        }
      }

      @media (max-width: 480px) {
        .page {
          padding: 0.9rem;
        }

        .audio-player-container {
          padding: 1rem 0.9rem 0.85rem;
        }

        .audio-header-text p {
          font-size: 0.8rem;
        }

        .primary-control,
        .secondary-control {
          width: 100%;
        }
      }
    </style>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const audio = document.getElementById("audioElement");
        const playPauseBtn = document.getElementById("playPauseBtn");
        const volumeSlider = document.getElementById("volumeSlider");
        const speedSlider = document.getElementById("speedSlider");
        const repeatBtn = document.getElementById("repeatBtn");
        const progressBar = document.getElementById("progressBar");
        const currentTimeSpan = document.getElementById("currentTime"); // جديد
        const totalTimeSpan = document.getElementById("totalTime"); // جديد
        const volumeValueSpan = document.getElementById("volumeValue");
        const speedValueSpan = document.getElementById("speedValue");
        const canvas = document.getElementById("visualizerCanvas");
        const transcriptContainer = document.getElementById(
          "transcript-container",
        );
        const ctx = canvas.getContext("2d");

        // البيانات
        const words = [
          { text: "السؤال", start: 548, end: 888 },
          { text: "الاول", start: 888, end: 1288 },
          { text: "من", start: 1288, end: 2588 },
          { text: "ربك؟", start: 2588, end: 4188 },
          { text: "الاجابة", start: 4188, end: 5148 },
          { text: "ربي", start: 5148, end: 6368 },
          { text: "الله", start: 6368, end: 6908 },
          { text: "وهو", start: 6908, end: 7808 },
          { text: "رب", start: 7808, end: 8188 },
          { text: "العالمين.", start: 8188, end: 9108 },
        ];

        let isPlaying = false;
        let isRepeating = false;
        let audioContext;
        let source;
        let analyser;

        if (volumeValueSpan) {
          volumeValueSpan.textContent = `${Math.round(
            parseFloat(volumeSlider.value) * 100,
          )}%`;
        }

        if (speedValueSpan) {
          speedValueSpan.textContent = `${parseFloat(speedSlider.value).toFixed(
            1,
          )}x`;
        }

        // دالة لتنسيق الوقت (من الثواني إلى MM:SS)
        function formatTime(seconds) {
          const minutes = Math.floor(seconds / 60);
          const secs = Math.floor(seconds % 60);
          return `${minutes.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;
        }

        // تهيئة النص في الصفحة
        words.forEach((word, index) => {
          const span = document.createElement("span");
          span.textContent = word.text;
          span.classList.add("word");
          span.dataset.index = index;

          span.addEventListener("click", () => {
            audio.currentTime = word.start / 1000;
            if (!isPlaying) {
              audio.play();
              isPlaying = true;
              playPauseBtn.textContent = "إيقاف";
              setupAudioVisualization();
            }
          });

          transcriptContainer.appendChild(span);
          transcriptContainer.appendChild(document.createTextNode(" "));
        });

        // أحداث التحكم
        playPauseBtn.addEventListener("click", () => {
          if (isPlaying) {
            audio.pause();
            playPauseBtn.textContent = "تشغيل";
          } else {
            audio.play();
            playPauseBtn.textContent = "إيقاف";
            setupAudioVisualization();
          }
          isPlaying = !isPlaying;
        });

        volumeSlider.addEventListener("input", () => {
          audio.volume = volumeSlider.value;
          if (volumeValueSpan) {
            volumeValueSpan.textContent = `${Math.round(
              parseFloat(volumeSlider.value) * 100,
            )}%`;
          }
        });

        speedSlider.addEventListener("input", () => {
          audio.playbackRate = speedSlider.value;
          if (speedValueSpan) {
            speedValueSpan.textContent = `${parseFloat(
              speedSlider.value,
            ).toFixed(1)}x`;
          }
        });

        repeatBtn.addEventListener("click", () => {
          isRepeating = !isRepeating;
          repeatBtn.textContent = isRepeating ? "إلغاء التكرار" : "تكرار";
          repeatBtn.style.backgroundColor = isRepeating ? "#28a745" : "#007bff";
        });

        audio.addEventListener("ended", () => {
          if (isRepeating) {
            audio.currentTime = 0;
            audio.play();
          } else {
            isPlaying = false;
            playPauseBtn.textContent = "تشغيل";
          }
        });

        // إضافة هذه الأسطر الجديدة للتحكم في شريط التقدم وعرض الوقت
        audio.addEventListener("loadedmetadata", () => {
          progressBar.max = audio.duration;
          totalTimeSpan.textContent = formatTime(audio.duration);
        });

        audio.addEventListener("timeupdate", () => {
          progressBar.value = audio.currentTime;
          currentTimeSpan.textContent = formatTime(audio.currentTime);

          const currentTimeInMs = audio.currentTime * 1000;
          const spans = transcriptContainer.querySelectorAll(".word");

          let found = false;
          spans.forEach((span) => {
            const index = span.dataset.index;
            const word = words[index];
            if (currentTimeInMs >= word.start && currentTimeInMs < word.end) {
              if (!span.classList.contains("highlighted")) {
                spans.forEach((s) => s.classList.remove("highlighted"));
                span.classList.add("highlighted");
              }
              found = true;
            }
          });
          if (!found) {
            spans.forEach((s) => s.classList.remove("highlighted"));
          }
        });

        progressBar.addEventListener("input", () => {
          audio.currentTime = progressBar.value;
        });

        // إعداد Web Audio API للـ Visualization
        function setupAudioVisualization() {
          if (!audioContext) {
            audioContext = new (
              window.AudioContext || window.webkitAudioContext
            )();
            source = audioContext.createMediaElementSource(audio);
            analyser = audioContext.createAnalyser();

            source.connect(analyser);
            analyser.connect(audioContext.destination);

            analyser.fftSize = 2048;
            const bufferLength = analyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);

            function draw() {
              requestAnimationFrame(draw);
              analyser.getByteTimeDomainData(dataArray);

              ctx.clearRect(0, 0, canvas.width, canvas.height);
              ctx.lineWidth = 2;
              ctx.strokeStyle = "#6a5acd";
              ctx.beginPath();
              const sliceWidth = (canvas.width * 1.0) / bufferLength;
              let x = 0;

              for (let i = 0; i < bufferLength; i++) {
                const v = dataArray[i] / 128.0;
                const y = (v * canvas.height) / 2;
                if (i === 0) {
                  ctx.moveTo(x, y);
                } else {
                  ctx.lineTo(x, y);
                }
                x += sliceWidth;
              }
              ctx.lineTo(canvas.width, canvas.height / 2);
              ctx.stroke();
            }
            draw();
          }
        }
      });
    </script>
  </body>
</html>
